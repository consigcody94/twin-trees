  "_metadata": {
    "description": "Kabbalistic Tree of Life and Tree of Death (Qliphoth) structured data for 3D visualization",
    "coordinateSystem": {
      "note": "2D coordinates use a normalized grid. X: -1 (left/Severity) to +1 (right/Mercy), 0 = center/Mildness. Y: 0 (bottom/Malkuth) to 4 (top/Kether). Z: 0 for Tree of Life front plane; negative Z for Tree of Death (mirror/shadow). For 3D, the Tree of Death is reflected below or behind the Tree of Life, separated by the Abyss plane.",
      "pillars": {
        "left": { "name": "Pillar of Severity (Boaz)", "x": -1 },
        "center": { "name": "Pillar of Mildness (Equilibrium)", "x": 0 },
        "right": { "name": "Pillar of Mercy (Jachin)", "x": 1 }
      },
      "yLevels": {
        "level0": { "y": 0, "description": "Malkuth / Lilith-Nahemoth" },
        "level1": { "y": 1, "description": "Yesod-Hod-Netzach / Gamaliel-Samael-A'arab Zaraq" },
        "level2": { "y": 2, "description": "Tiphareth-Geburah-Chesed / Thagirion-Golachab-Gamchicoth" },
        "level3": { "y": 2.5, "description": "Da'at / The Abyss" },
        "level4": { "y": 3, "description": "Binah-Chokmah / Satariel-Ghagiel (Supernal)" },
        "level5": { "y": 4, "description": "Kether / Thaumiel (Crown)" }
      }
    },
    "sources": [
      "Aleister Crowley, Liber 777 (Queen Scale / Briah color attributions)",
      "Kenneth Grant, Nightside of Eden (Tunnels of Set)",
      "Golden Dawn tradition (path correspondences)",
      "Hermetic Qabalah (sephirothic structure)"
    ]
  },

