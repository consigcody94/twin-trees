  "daat": {
    "nameHebrew": "Da'at",
    "hebrewScript": "\u05d3\u05e2\u05ea",
    "nameEnglish": "Knowledge",
    "number": "Hidden (unnumbered, sometimes called the 11th)",
    "position": { "x": 0, "y": 2.5, "z": 0 },
    "description": "The hidden or invisible sephira. Not counted among the ten Sephiroth. It sits on the Middle Pillar directly above Tiphareth, acting as the gateway between the Supernal Triad (Kether, Chokmah, Binah) and the lower seven sephiroth.",
    "color": "Lavender-Grey (translucent/invisible in many traditions)",
    "colorHex": "#B4A7C7",
    "opacity": 0.5,

    "roles": {
      "bridge": "Da'at bridges the Abyss, allowing divine influx from the Supernal Triad to flow downward to the lower sephiroth. It is the point where Chokmah (Wisdom) and Binah (Understanding) unite to produce Knowledge.",
      "abyss": "The Abyss is the great gulf separating the three Supernal sephiroth from the seven lower ones. Da'at marks this boundary. Crossing the Abyss is described as a profound spiritual trial, a dark night of the soul requiring dissolution of the ego.",
      "gateway": "Da'at is simultaneously a veil and a gateway, a separation and a connection. It serves as the primary portal between the Tree of Life and the Tree of Death. The backside of the Tree of Life can only be accessed through the gateway of Da'at.",
      "membrane": "Da'at functions not as a door but as a fluctuating membrane through which one may or may not be permitted to pass. It is the thin boundary between the manifest sephiroth and the unmanifest/shadow realms.",
      "mirror": "Da'at acts as a mirror reflecting divine consciousness into human awareness, the space where idea and reality intersect."
    },

    "choronzon": {
      "name": "Choronzon (333)",
      "role": "The Demon of the Abyss, lord of the Qliphothic domains, guardian and chief initiator of the gateway at Da'at. Known as the Dweller in the Abyss who disperses consciousness into chaos. Must be confronted when crossing the Abyss."
    },

    "geometricRelationships": {
      "aboveTriangle": "Forms the apex of a downward-pointing triangle with Chesed and Geburah",
      "belowTriangle": "Forms the nadir of an upward-pointing triangle with Chokmah and Binah",
      "centerColumn": "Sits on the Middle Pillar between Kether (y=4) and Tiphareth (y=2)"
    }
  },

  "treeOfDeath": {
    "name": "Qliphoth (Tree of Death / Tree of Shells)",
    "description": "The shadow or reverse side of the Tree of Life. The Qliphoth (Hebrew: shells, husks, peels) represent the remnants of the shattered vessels that failed to contain divine light during creation. Each Qlipha is the dark mirror of its corresponding Sephira. The Tree of Death is accessed through Da'at and extends downward/behind as an inverted reflection.",

    "mirrorNote": "In 3D visualization, the Tree of Death can be positioned as: (A) an inverted reflection below the Tree of Life, sharing Malkuth/Lilith as the junction point, (B) behind the Tree of Life on the negative Z-axis, accessed through Da'at, or (C) both inverted AND behind, creating a diagonal shadow. The positions below use the 'inverted below' model with negative Y values.",

